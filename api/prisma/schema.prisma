generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum FinancialAccountType {
  CASH
  BANK
  CREDIT_CARD
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountStatus {
  PENDING
  PAID
  OVERDUE
}

enum RecurrenceType {
  NONE
  MONTHLY
  YEARLY
  CUSTOM
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  name              String
  email             String             @unique
  password_hash     String
  role              Role               @default(USER)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  deleted_at        DateTime?
  
  financial_accounts FinancialAccount[]
  categories        Category[]
  cost_centers      CostCenter[]
  accounts          Account[]
  audit_logs        AuditLog[]

  @@map("users")
}

model FinancialAccount {
  id              String               @id @default(uuid()) @db.Uuid
  name            String
  type            FinancialAccountType
  initial_balance Decimal              @db.Decimal(15, 2)
  created_by      String               @db.Uuid
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  deleted_at      DateTime?

  user            User                 @relation(fields: [created_by], references: [id])
  accounts        Account[]

  @@index([created_by])
  @@index([type])
  @@map("financial_accounts")
}

model Category {
  id         String          @id @default(uuid()) @db.Uuid
  name       String
  type       TransactionType
  parent_id  String?         @db.Uuid
  created_by String          @db.Uuid
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  deleted_at DateTime?

  user           User       @relation(fields: [created_by], references: [id])
  parent         Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  sub_categories Category[] @relation("SubCategories")
  accounts       Account[]

  @@index([type])
  @@index([created_by])
  @@index([parent_id])
  @@map("categories")
}

model CostCenter {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  created_by String    @db.Uuid
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user       User      @relation(fields: [created_by], references: [id])
  accounts   Account[]

  @@index([created_by])
  @@map("cost_centers")
}

model Account {
  id                   String          @id @default(uuid()) @db.Uuid
  description          String
  type                 TransactionType
  category_id          String          @db.Uuid
  cost_center_id       String?         @db.Uuid
  financial_account_id String          @db.Uuid
  amount               Decimal         @db.Decimal(15, 2)
  competence_date      DateTime        @db.Date
  due_date             DateTime        @db.Date
  payment_date         DateTime?       @db.Date
  status               AccountStatus   @default(PENDING)
  recurrence_type      RecurrenceType  @default(NONE)
  recurrence_interval  Int?
  is_fixed             Boolean         @default(false)
  created_by           String          @db.Uuid
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt
  deleted_at           DateTime?

  user              User             @relation(fields: [created_by], references: [id])
  category          Category         @relation(fields: [category_id], references: [id])
  cost_center       CostCenter?      @relation(fields: [cost_center_id], references: [id])
  financial_account FinancialAccount @relation(fields: [financial_account_id], references: [id])

  @@index([due_date])
  @@index([competence_date])
  @@index([status])
  @@index([type])
  @@index([created_by])
  @@index([category_id])
  @@index([financial_account_id])
  @@map("accounts")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  action     String
  entity     String
  entity_id  String
  metadata   Json?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([entity])
  @@index([created_at])
  @@map("audit_logs")
}
